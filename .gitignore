# =============================================================================
# SMART QUIZ SYSTEM - ROOT .gitignore
# =============================================================================

# --- Secrets & local env ----------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
!**/jwt/*.pub.pem
secrets/
ops/.secrets/

# --- Java / Gradle / Maven --------------------------------------------------
**/build/
**/.gradle/
**/out/
**/target/
**/bin/
**/*.class
**/*.jar
**/*.war
!gradle/wrapper/gradle-wrapper.jar
**/hs_err_pid*
**/replay_pid*

# --- Node / Next.js / pnpm --------------------------------------------------
**/node_modules/
**/.next/
**/.turbo/
**/.nx/
**/dist/
**/.pnpm-store/
**/coverage/
**/.eslintcache
**/.parcel-cache/

# --- Python / Poetry / uv ---------------------------------------------------
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/
**/pip-log.txt
**/.hypothesis/

# --- Docker / Compose volumes / local data ---------------------------------
**/data/
**/*.log
logs/

# --- IDE / Editor -----------------------------------------------------------
.idea/
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.swp
*.swo
*~

# --- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Build artifacts / temp -------------------------------------------------
tmp/
temp/
.cache/
*.tmp

# --- Testing / coverage ------------------------------------------------------
.nyc_output/
coverage.xml
htmlcov/
jacoco.exec

# --- Generated code (OpenAPI, Avro, Protobuf) -------------------------------
**/generated/
**/generated-sources/

# --- Local Claude / MCP state (nhưng giữ config) ----------------------------
.claude/settings.local.json
