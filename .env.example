# =============================================================================
# SMART QUIZ SYSTEM - ROOT .env.example
# =============================================================================
# Copy file này sang .env cho dev local:
#   cp .env.example .env
# Mỗi service có .env.example riêng (services/<name>/.env.example) — file này
# chỉ chứa biến dùng chung hoặc tham chiếu nhanh cho developer.
# =============================================================================

# --- Environment flag --------------------------------------------------------
ENV=local

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartquiz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Connection string mẫu:
# jdbc:postgresql://localhost:5432/smartquiz?currentSchema=public

# --- MongoDB -----------------------------------------------------------------
MONGODB_URI=mongodb://root:root@localhost:27017/smartquiz?authSource=admin

# --- Redis HOT (session thi, AOF everysec, noeviction) -----------------------
REDIS_HOT_HOST=localhost
REDIS_HOT_PORT=6379

# --- Redis CACHE (rate limit, ai cache, LRU) ---------------------------------
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6380

# --- ClickHouse --------------------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=smartquiz_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Elasticsearch -----------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# --- Kafka -------------------------------------------------------------------
# Trong docker network dùng kafka:9092; host dev dùng localhost:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081/apis/ccompat/v7

# --- MinIO / S3 --------------------------------------------------------------
S3_ENDPOINT=http://localhost:9001
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PROCTORING=sq-proctoring
S3_BUCKET_CERTIFICATES=sq-certificates
S3_BUCKET_IMPORTS=sq-imports
S3_BUCKET_AI_EXPORTS=sq-ai-exports

# --- Mail (MailHog local) ----------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@smartquiz.local

# --- JWT / JWKS (Auth service là IDP) ---------------------------------------
# Sinh keypair bằng: ops/gen-jwt-keypair.sh  (chưa tạo — làm khi scaffold auth)
JWT_PRIVATE_KEY_PATH=./ops/keys/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./ops/keys/jwt.public.pem
JWT_ISSUER=https://auth.smartquiz.local
JWT_ACCESS_TTL_SECONDS=900      # 15 phút
JWT_REFRESH_TTL_SECONDS=2592000 # 30 ngày

# --- AI / LLM ---------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-large

# --- Service ports (để tránh đụng nhau khi dev song song) -------------------
AUTH_SERVICE_PORT=8101
EXAM_SERVICE_PORT=8102
QUESTION_SERVICE_PORT=8103
ANALYTICS_SERVICE_PORT=8104
CHEAT_DETECTION_PORT=8105
AI_SERVICE_PORT=8201
WEB_PORT=3000
