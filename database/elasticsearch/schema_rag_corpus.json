{
    "settings": {
        "number_of_shards": 3,
        "number_of_replicas": 1,
        "refresh_interval": "30s",
        "index.lifecycle.name": "rag_corpus_ilm",
        "index.lifecycle.rollover_alias": "rag_corpus",
        "analysis": {
            "filter": {
                "vi_stop": {
                    "type": "stop",
                    "stopwords": ["và", "của", "là", "có", "cho", "với", "trong", "một", "các", "để", "này", "đó"]
                }
            },
            "analyzer": {
                "vi_analyzer": {
                    "type": "custom",
                    "tokenizer": "standard",
                    "filter": ["lowercase", "vi_stop"]
                }
            }
        }
    },
    "mappings": {
        "properties": {
            "chunk_id":      { "type": "keyword" },
            "corpus_id":     { "type": "keyword" },
            "source_doc":    { "type": "keyword" },
            "subject_code":  { "type": "keyword" },
            "topic":         { "type": "keyword" },
            "language":      { "type": "keyword" },

            "text": {
                "type": "text",
                "analyzer": "vi_analyzer"
            },
            "tokens_count":  { "type": "integer" },
            "chunk_index":   { "type": "integer" },

            "embedding": {
                "type": "dense_vector",
                "dims": 1536,
                "index": true,
                "similarity": "cosine",
                "index_options": { "type": "hnsw", "m": 16, "ef_construction": 100 }
            },

            "created_by":  { "type": "keyword" },
            "created_at":  { "type": "date" },
            "updated_at":  { "type": "date" }
        }
    }
}
