{
    "namespace": "com.smartquiz.events.grading",
    "name": "GradingResult",
    "type": "record",
    "doc": "AI Service trả kết quả về cho Exam Service. confidence < threshold → route sang manual grading queue (giáo viên chấm).",
    "fields": [
        { "name": "envelope",         "type": "com.smartquiz.events.common.EventEnvelope" },
        { "name": "submission_id",    "type": "string" },
        { "name": "attempt_id",       "type": "string" },
        { "name": "question_ref_id",  "type": "string" },
        { "name": "points_earned",    "type": "double" },
        { "name": "max_points",       "type": "double" },
        { "name": "is_correct",       "type": ["null", "boolean"], "default": null },
        { "name": "confidence",       "type": "double", "doc": "0.0 - 1.0. < 0.75 → đẩy sang manual queue" },
        { "name": "grading_method",   "type": {
            "type": "enum",
            "name": "GradingMethod",
            "symbols": ["AUTO", "AI_LLM", "MANUAL", "HYBRID"]
        }},
        { "name": "model_used",       "type": ["null", "string"], "default": null },
        { "name": "prompt_version",   "type": ["null", "string"], "default": null },
        { "name": "rationale",        "type": ["null", "string"], "default": null, "doc": "Lý do chấm (hiển thị cho giáo viên review)" },
        { "name": "input_tokens",     "type": ["null", "int"],    "default": null },
        { "name": "output_tokens",    "type": ["null", "int"],    "default": null },
        { "name": "cost_usd",         "type": ["null", "double"], "default": null },
        { "name": "error",            "type": ["null", "string"], "default": null, "doc": "Khác null = chấm thất bại, Exam phải retry hoặc fallback manual" }
    ]
}
